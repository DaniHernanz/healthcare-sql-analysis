-- =============================================================================== --
-- SECCIÓN 1: CREACIÓN DE TABLAS Y DATOS
-- =============================================================================== --
-- Dataset simulado inspirado en la estructura de MIMIC-IV,
-- el estándar de referencia en datos clínicos para IA en salud.
-- Incluye pacientes, ingresos, diagnósticos, prescripciones
-- y resultados de laboratorio.
-- =============================================================================== --

CREATE TABLE patients (
    patient_id  INT PRIMARY KEY,
    gender      VARCHAR(1),
    age         INT,
    insurance   VARCHAR(50)
);

CREATE TABLE admissions (
    admission_id    INT PRIMARY KEY,
    patient_id      INT,
    admission_date  DATE,
    discharge_date  DATE,
    admission_type  VARCHAR(50),
    diagnosis       VARCHAR(100)
);

CREATE TABLE diagnoses (
    diagnosis_id  INT PRIMARY KEY,
    admission_id  INT,
    icd_code      VARCHAR(10),
    description   VARCHAR(100),
    sequence      INT
);

CREATE TABLE prescriptions (
    prescription_id  INT PRIMARY KEY,
    admission_id     INT,
    drug             VARCHAR(100),
    start_date       DATE,
    end_date         DATE
);

CREATE TABLE lab_results (
    lab_id      INT PRIMARY KEY,
    patient_id  INT,
    admission_id INT,
    test_name   VARCHAR(100),
    value       NUMERIC,
    unit        VARCHAR(20),
    test_date   DATE
);

